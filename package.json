{
  "name": "ai-consistency-platform",
  "version": "1.0.0",
  "description": "Multi-user AI preference consistency platform with MCP server",
  "main": "dist/server.js",
  "scripts": {
    "prepare": "npm run build && node scripts/postinstall-rebuild-sqlite.cjs",
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "mcp:stdio": "node dist/mcp-stdio.js",
    "rebuild:cursor-mcp": "bash scripts/rebuild-for-cursor-mcp.sh",
    "lint:preferences": "node dist/cli-lint.js"
  },
  "type": "commonjs",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.9.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.1",
    "express-session": "^1.17.3",
    "stripe": "^22.1.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.8",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.17.10",
    "@types/node": "^20.11.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
